import re

with open('index.html', 'r') as f:
    html = f.read()

pattern = re.compile(
    r'[ \t]*\.product-proof__(?:videos|video-card)[^{]*\{[^}]*\}\n?',
    re.MULTILINE
)
removed = pattern.findall(html)
print(f'Removed {len(removed)} stale rules')
html = pattern.sub('', html)

new_css = """      .product-proof__videos {
        position: relative;
        height: 560px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .product-proof__video-card {
        position: absolute;
        width: 240px;
        aspect-ratio: 9 / 16;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 24px 60px rgba(0,0,0,0.2);
        transition: transform 0.4s ease;
        background: #f5f5f5;
      }
      .product-proof__video-card:nth-child(1) {
        transform: rotate(-9deg) translateX(-170px);
        z-index: 1;
      }
      .product-proof__video-card:nth-child(2) {
        transform: rotate(-1deg) translateY(-24px);
        z-index: 3;
      }
      .product-proof__video-card:nth-child(3) {
        transform: rotate(7deg) translateX(170px);
        z-index: 2;
      }
      .product-proof__video-card:hover {
        transform: rotate(0deg) scale(1.04);
        z-index: 10;
      }
      .product-proof__video-card video {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        object-fit: cover;
        display: block;
      }
      @media (max-width: 900px) {
        .product-proof__videos { height: 440px; }
        .product-proof__video-card { width: 180px; }
        .product-proof__video-card:nth-child(1) { transform: rotate(-9deg) translateX(-110px); }
        .product-proof__video-card:nth-child(3) { transform: rotate(7deg) translateX(110px); }
      }
"""

section_re = re.compile(
    r'(<section class="product-proof"[^>]*>\s*<style>)([\s\S]*?)(\s*</style>)'
)
m = section_re.search(html)
if not m:
    raise SystemExit('ERROR: product-proof <style> block not found')

html = html[:m.end(2)] + '\n' + new_css + html[m.start(3):]

with open('index.html', 'w') as f:
    f.write(ht
html = open('index.html').read()

old = '''      .product-proof__inner {
        max-width: 1240px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr;
        gap: 28px;
        align-items: center;
      }'''

new = '''      .product-proof__inner {
        max-width: 1240px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 420px 1fr;
        gap: 48px;
        align-items: center;
      }'''

if old in html:
    html = html.replace(old, new, 1)
    open('index.html', 'w').write(html)
    print('Done!')
else:
    print('Not found')
