  <!-- HERO -->
  <section class="hero" id="hero">
    <video class="hero__video" id="heroBgVideo" autoplay muted playsinline>
      <source src="assets/hero-video-2.mp4" type="video/mp4">
    </video>
    <div class="hero__overlay">
      <div class="hero__content">
        <div class="hero__brand-mark">
          <img src="assets/logo.png" alt="wype W" class="hero__brand-w">
          <span class="hero__brand-wordmark">wype<sup>®</sup></span>
        </div>
        <div class="hero__badge">NANO WAVE TECHNOLOGY</div>
        <h1 class="hero__title">
          Just <span>Wype It.</span>
        </h1>
        <p class="hero__sub">The <span class="hero__sub-cycle" id="heroSubCycle">streak-free</span> cloth for people who care about their car.</p>
        <div class="hero__actions">
          <a href="#order" class="btn btn--white">Order Now</a>
          <a href="#products" class="btn btn--ghost">See Our Products</a>
        </div>
        <div class="hero__stats">
          <div class="hero__stat">
            <span class="hero__stat-num">1200</span>
            <span class="hero__stat-label">GSM Nano Wave</span>
          </div>
          <div class="hero__stat-divider"></div>
          <div class="hero__stat">
            <span class="hero__stat-num">90×70</span>
            <span class="hero__stat-label">cm Per Cloth</span>
          </div>
          <div class="hero__stat-divider"></div>
          <div class="hero__stat">
            <span class="hero__stat-num">EU</span>
            <span class="hero__stat-label">Made in Europe</span>
          </div>
        </div>
        <div class="hero__payment-trust">
          <span class="hero__payment-trust-label">Secure checkout:</span>
          <span class="hero__pay-badge hero__pay-badge--apple">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M11.1 7.4c0-1.7 1.4-2.5 1.5-2.6-.8-1.2-2.1-1.4-2.6-1.4-1.1-.1-2.1.6-2.7.6-.6 0-1.5-.6-2.4-.6C3.6 3.4 2 4.5 2 7c0 1.5.6 3.1 1.3 4.2.7 1 1.3 1.8 2.2 1.8.9 0 1.2-.6 2.3-.6 1.1 0 1.4.6 2.3.6.9 0 1.6-.9 2.2-1.9.4-.7.6-1.3.7-1.4C12.9 9.6 11.1 8.9 11.1 7.4zM9.3 2.3C10 1.5 10.3.5 10.2 0 9.3.1 8.2.6 7.5 1.4c-.7.7-1.1 1.7-1 2.6C7.5 4 8.5 3.5 9.3 2.3z"/></svg>
            Apple Pay
          </span>
          <span class="hero__pay-badge hero__pay-badge--google">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google Pay
          </span>
          <span class="hero__pay-badge hero__pay-badge--klarna">
            <svg width="14" height="9" viewBox="0 0 68 40" fill="currentColor"><path d="M6.4 0H0v40h6.4V0zM40 0h-6.4v40H40V0zM53.6 0H47v40h6.6V0zM22.2 0H15.8v40h6.4V0zM68 20c0 11-9 20-20 20h-1.4V0H48c11 0 20 9 20 20z"/></svg>
            Klarna
          </span>
          <span class="hero__pay-badge hero__pay-badge--visa">
            <svg viewBox="0 0 60 20" width="42" height="14" xmlns="http://www.w3.org/2000/svg">
              <text x="30" y="15" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="900" font-size="17" fill="white" font-style="italic" letter-spacing="1.5">VISA</text>
            </svg>
          </span>
          <span class="hero__pay-badge hero__pay-badge--mc">
            <svg viewBox="0 0 36 22" width="36" height="22" xmlns="http://www.w3.org/2000/svg">
              <circle cx="13" cy="11" r="10" fill="#EB001B"/>
              <circle cx="23" cy="11" r="10" fill="#F79E1B" opacity="0.9"/>
              <path d="M18 2.6a10 10 0 0 1 0 16.8A10 10 0 0 1 18 2.6z" fill="#FF5F00"/>
            </svg>
          </span>
        </div>
