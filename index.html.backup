              <a href="wype-plus.html" class="btn btn--outline btn--full" style="border-color:rgba(255,255,255,0.25);color:rgba(255,255,255,0.85);">Full Details</a>
              <button class="btn btn--primary btn--full" onclick="Cart.add('wype-plus',1)">Add to Basket</button>
