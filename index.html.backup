  <!-- STICKY CTA -->
  <div class="sticky-cta" id="stickyCta">
    <span class="sticky-cta__label">
      <svg class="sticky-cta__crown" width="18" height="18" viewBox="0 0 100 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Royal Mail style crown -->
        <path d="M50 8 C50 8 44 18 38 14 C32 10 34 2 28 4 C22 6 24 16 18 18 C12 20 8 14 8 14 L14 52 L86 52 L92 14 C92 14 88 20 82 18 C76 16 78 6 72 4 C66 2 68 10 62 14 C56 18 50 8 50 8Z" fill="white"/>
        <rect x="14" y="56" width="72" height="6" rx="2" fill="white"/>
        <rect x="14" y="65" width="72" height="10" rx="3" fill="white"/>
        <!-- Fleur-de-lis left -->
        <ellipse cx="28" cy="36" rx="4" ry="6" fill="#E01E1E"/>
        <ellipse cx="28" cy="28" rx="3" ry="4" fill="#E01E1E"/>
        <!-- Fleur-de-lis center -->
        <ellipse cx="50" cy="34" rx="4" ry="6" fill="#E01E1E"/>
        <ellipse cx="50" cy="26" rx="3" ry="4" fill="#E01E1E"/>
        <!-- Fleur-de-lis right -->
        <ellipse cx="72" cy="36" rx="4" ry="6" fill="#E01E1E"/>
        <ellipse cx="72" cy="28" rx="3" ry="4" fill="#E01E1E"/>
        <!-- Cross on top -->
        <rect x="48" y="0" width="4" height="10" rx="1" fill="white"/>
        <rect x="44" y="3" width="12" height="4" rx="1" fill="white"/>
        <!-- Base studs -->
        <rect x="20" y="58" width="8" height="4" rx="1" fill="#E01E1E"/>
        <rect x="34" y="58" width="8" height="4" rx="1" fill="#E01E1E"/>
        <rect x="58" y="58" width="8" height="4" rx="1" fill="#E01E1E"/>
        <rect x="72" y="58" width="8" height="4" rx="1" fill="#E01E1E"/>
      </svg>
      Free delivery over £25
    </span>
    <a href="#order" id="stickyCheckoutBtn" class="btn-sticky-cta" onclick="if(Cart&&Cart.totalQty()>0){event.preventDefault();CartDrawer.open();}">View Basket / Order Now</a>
  </div>

  <script src="cart.js"></script>
  <script src="script.js"></script>
  <script>
    // ── Kota-style nav panel ──
    const menuBtn    = document.getElementById('menuBtn');
    const panelClose = document.getElementById('panelClose');
    const navPanel   = document.getElementById('navPanel');
    const navOverlay = document.getElementById('navOverlay');

    function openPanel() {
      navPanel.classList.add('open');
      navOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closePanel() {
      navPanel.classList.remove('open');
      navOverlay.classList.remove('open');
      document.body.style.overflow = '';
    }

    menuBtn.addEventListener('click', openPanel);
    panelClose.addEventListener('click', closePanel);
    navOverlay.addEventListener('click', closePanel);

    // Products dropdown — portal pattern avoids transform stacking context trap
    function toggleNavDrop() {
      const btn = document.getElementById('navProductsBtn');
      const dd  = document.getElementById('navDropdown');
      if (!dd) return;
      const isOpen = dd.classList.contains('open');
      if (!isOpen) {
        const r = btn.getBoundingClientRect();
        dd.style.top  = (r.bottom + 8) + 'px';
        dd.style.left = r.left + 'px';
      }
      dd.classList.toggle('open');
    }
    document.addEventListener('click', function(e) {
      const btn = document.getElementById('navProductsBtn');
      const dd  = document.getElementById('navDropdown');
      if (dd && btn && !btn.contains(e.target) && !dd.contains(e.target)) {
        dd.classList.remove('open');
      }
    });

    // Close panel when any anchor link inside it is clicked
    navPanel.querySelectorAll('.nav__panel-anchor').forEach(a => {
      a.addEventListener('click', closePanel);
    });

    // Pricing tables
    const HOME_PRICES = {
      'nanowype':  { 1: { per: 16.00, total: 19.99  }, 2: { per: 12.80, total: 25.60 }, 5: { per: 11.20, total: 56.00 } },
      'wype-plus': { 1: { per: 12.80, total: 16.79  }, 2: { per: 10.24, total: 20.48 }, 5: { per:  8.96, total: 44.80 } },
    };
    let _homeProduct = 'nanowype';
    let _homeQty     = 1;

    function setHomeProduct(product) {
      _homeProduct = product;
      const isNano = product === 'nanowype';
      document.getElementById('homeTabNano').style.background = isNano ? '#E01E1E' : '#111';
      document.getElementById('homeTabNano').style.color      = '#fff';
      document.getElementById('homeTabWype').style.background = isNano ? '#111' : '#E01E1E';
      document.getElementById('homeTabWype').style.color      = '#fff';
      const p = HOME_PRICES[product];
      document.getElementById('hbPrice1').innerHTML = '£' + p[1].per.toFixed(2) + '<span class="p-bundle__per">/towel</span>';
      document.getElementById('hbDel1').textContent  = '+ £3.99 delivery';
      document.getElementById('hbPrice2').innerHTML = '£' + p[2].per.toFixed(2) + '<span class="p-bundle__per">/towel</span>';
      document.getElementById('hbTotal2').textContent = '£' + p[2].total.toFixed(2) + ' total';
      document.getElementById('hbPrice5').innerHTML = '£' + p[5].per.toFixed(2) + '<span class="p-bundle__per">/towel</span>';
      document.getElementById('hbTotal5').textContent = '£' + p[5].total.toFixed(2) + ' total';
      updateHomeCheckoutUrl();
    }

    function setHomeBundle(qty) {
      _homeQty = qty;
      [1,2,5].forEach(q => {
        const map = {1:'hb1',2:'hb2',5:'hb3'};
        document.getElementById(map[q]).classList.toggle('p-bundle--selected', q === qty);
      });
      updateHomeCheckoutUrl();
    }

    function updateHomeCheckoutUrl() {
      /* URL no longer used — slide adds to basket */
    }

    // ── Slide-to-order button ──
    (function() {
      const wrap   = document.getElementById('slideBtnWrap');
      const handle = document.getElementById('slideBtnHandle');
      const fill   = document.getElementById('slideBtnFill');
      const label  = document.getElementById('slideBtnLabel');
      if (!wrap || !handle) return;

      const TRACK = 240; // max translateX
      const THRESH = 0.88;
      let dragging = false, startX = 0, curX = 0;

      function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
      function cx(e) { return e.touches ? e.touches[0].clientX : e.clientX; }

      function setPos(x) {
        curX = clamp(x, 0, TRACK);
        handle.style.transform = 'translateY(-50%) translateX(' + curX + 'px)';
        fill.style.width = (curX + 52) + 'px';
        label.style.opacity = Math.max(0, 1 - (curX / TRACK) * 1.5);
      }

      function spring(targetX) {
        handle.style.transition = 'transform 0.42s cubic-bezier(0.16,1,0.3,1)';
        fill.style.transition   = 'width 0.42s cubic-bezier(0.16,1,0.3,1)';
        setPos(targetX);
        setTimeout(function() {
          handle.style.transition = '';
          fill.style.transition   = '';
        }, 450);
      }

      handle.addEventListener('mousedown', function(e) {
        dragging = true; startX = cx(e) - curX;
        handle.style.transition = 'none'; fill.style.transition = 'none';
        e.preventDefault();
      });
      handle.addEventListener('touchstart', function(e) {
        dragging = true; startX = cx(e) - curX;
        handle.style.transition = 'none'; fill.style.transition = 'none';
      }, { passive: true });

      document.addEventListener('mousemove', function(e) {
        if (!dragging) return;
        setPos(cx(e) - startX);
      });
      document.addEventListener('touchmove', function(e) {
        if (!dragging) return;
        setPos(cx(e) - startX);
      }, { passive: true });

      function onEnd() {
        if (!dragging) return;
        dragging = false;
        if (curX / TRACK >= THRESH) {
          spring(TRACK);
          wrap.classList.add('completed');
          label.textContent = '✓ Added to basket!';
          label.style.opacity = '1';
          handle.style.opacity = '0';
          setTimeout(function() {
            Cart.add(_homeProduct, _homeQty);
            setTimeout(function() {
              wrap.classList.remove('completed');
              handle.style.opacity = '1';
              label.textContent = 'Slide to Add to Basket';
              spring(0);
            }, 1800);
          }, 600);
        } else {
          spring(0);
        }
      }
      document.addEventListener('mouseup', onEnd);
      document.addEventListener('touchend', onEnd);
    })();

    // ── Hero cycling subtitle ──
    (function() {
      const el = document.getElementById('heroSubCycle');
      if (!el) return;
      const words = ['streak-free', 'glass-safe', 'paint-safe', 'pro-grade', 'nano wave'];
      let idx = 0;
      setInterval(function() {
        el.classList.add('cycle-out');
        setTimeout(function() {
          idx = (idx + 1) % words.length;
          el.textContent = words[idx];
          el.classList.remove('cycle-out');
          el.classList.add('cycle-in');
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              el.classList.remove('cycle-in');
            });
          });
        }, 320);
      }, 2600);
    })();

    // ── GSM section animations ──
    (function() {
      // 1. Card entrance + stat counter
      const cardObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          const card = entry.target;
          card.classList.add('gsm-visible');

          // Animate stat number
          const statEl = card.querySelector('.gsm-explainer__stat');
          if (statEl && !statEl._counted) {
            statEl._counted = true;
            const target  = parseFloat(statEl.dataset.count);
            const suffix  = statEl.dataset.suffix || '';
            if (target === 0) { statEl.textContent = '0' + suffix; return; }
            const duration = 1200;
            const start    = performance.now();
            function tick(now) {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              // ease-out cubic
              const ease = 1 - Math.pow(1 - progress, 3);
              const current = Math.round(ease * target);
              statEl.textContent = current + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
          }
          cardObserver.unobserve(card);
        });
      }, { threshold: 0.25 });

      document.querySelectorAll('.gsm-explainer__item').forEach(function(card) {
        cardObserver.observe(card);
      });

      // 2. Bar chart animation
      const barObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('gsm-bars-visible');
          barObserver.unobserve(entry.target);
        });
      }, { threshold: 0.2 });

      const compareEl = document.querySelector('.gsm-compare');
      if (compareEl) barObserver.observe(compareEl);
    })();
  </script>
  <script src="animations.js"></script>
  <!-- Products dropdown portal — lives on body so nav transform doesn't trap it -->
  <div class="nav__dropdown" id="navDropdown" style="position:fixed;z-index:99999;">
    <a href="nanowype-plus.html">NanoWype+™<span>1200 GSM</span></a>
    <a href="wype-plus.html">Micro wype+™<span>Pro Grade</span></a>
    <a href="trade.html">Trade Account</a>
  </div>
</body>
</html>
