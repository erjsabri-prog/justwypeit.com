      <span>Free UK delivery on orders over £25</span>
      <span class="announcement__dot">•</span>
      <span>Machine washable up to 300 washes</span>
    </div>
  </div>

  <!-- SCROLLING WAVY MARQUEE -->
  <div class="wave-marquee">
    <svg class="wave-marquee__svg" xmlns="http://www.w3.org/2000/svg" width="3600" height="110" aria-hidden="true">
      <defs>
        <path id="wave-bg-path" d="M0,55 C200,22 400,22 600,55 C800,88 1000,88 1200,55 C1400,22 1600,22 1800,55 C2000,88 2200,88 2400,55 C2600,22 2800,22 3000,55 C3200,88 3400,88 3600,55 L3600,110 L0,110 Z"/>
        <path id="wave-text-path" d="M0,50 C200,17 400,17 600,50 C800,83 1000,83 1200,50 C1400,17 1600,17 1800,50 C2000,83 2200,83 2400,50 C2600,17 2800,17 3000,50 C3200,83 3400,83 3600,50"/>
      </defs>
      <use href="#wave-bg-path" fill="#CC0000"/>
      <text font-family="'Rajdhani', sans-serif" font-size="18" font-weight="800" fill="white" letter-spacing="6">
        <textPath href="#wave-text-path" startOffset="0">JUST WYPE IT  ✦  JUST WYPE IT  ✦  JUST WYPE IT  ✦  JUST WYPE IT  ✦  JUST WYPE IT  ✦  JUST WYPE IT  ✦  JUST WYPE IT  ✦  JUST WYPE IT  ✦</textPath>
      </text>
    </svg>
  </div>
  <style>
    .wave-marquee {
      overflow: hidden;
      margin-top: 56px;
      line-height: 0;
    }
    .wave-marquee__svg {
      display: block;
      animation: wave-roll 16s linear infinite;
      will-change: transform;
    }
    @keyframes wave-roll {
      0%   { transform: translateX(0);     animation-timing-function: ease-in-out; }
      35%  { transform: translateX(-600px); animation-timing-function: linear; }
      50%  { transform: translateX(-600px); animation-timing-function: ease-in-out; }
      85%  { transform: translateX(-1200px); animation-timing-function: linear; }
      100% { transform: translateX(-1200px); }
    }
  </style>

  <!-- IN ACTION VIDEOS -->
  <section style="padding:80px 0 100px;background:#0d0d0d;">
    <style>
      .av-layout { display:grid; grid-template-columns:1fr 1fr; gap:60px; max-width:1060px; margin:0 auto; align-items:center; padding:0 24px; }
      .av-text__tag { font-family:'Rajdhani',sans-serif; font-size:11px; font-weight:700; letter-spacing:3px; text-transform:uppercase; color:#E01E1E; margin-bottom:16px; }
      .av-text h2 { font-family:'Rajdhani',sans-serif; font-size:42px; font-weight:900; color:#fff; line-height:1.1; margin:0 0 16px; text-transform:uppercase; }
      .av-text p { font-family:'Inter',sans-serif; font-size:15px; color:rgba(255,255,255,0.5); line-height:1.75; margin:0 0 28px; }
      .av-text__btns { display:flex; flex-direction:column; gap:12px; }
      .av-text__btn { display:inline-flex; align-items:center; justify-content:space-between; padding:14px 20px; border-radius:12px; font-family:'Rajdhani',sans-serif; font-size:15px; font-weight:700; letter-spacing:0.5px; text-decoration:none; transition:background 0.2s,transform 0.15s; color:#fff; }
      .av-text__btn:hover { transform:translateX(4px); }
      .av-text__btn--nano { background:#E01E1E; }
      .av-text__btn--nano:hover { background:#c01818; }
      .av-text__btn--micro { background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12); }
      .av-text__btn--micro:hover { background:rgba(255,255,255,0.12); }
      .av-text__btn span { font-size:12px; opacity:0.55; font-weight:400; }
      .av-cards { display:flex; gap:14px; align-items:flex-start; }
      .av-card { background:#161616; border-radius:20px; overflow:hidden; border:1px solid rgba(255,255,255,0.07); flex:1; }
      .av-card:first-child { transform:rotate(-2deg); }
      .av-card:last-child { transform:rotate(1.5deg); margin-top:28px; }
      .av-card__head { padding:13px 15px 7px; display:flex; align-items:center; gap:8px; }
      .av-card__dot { width:7px; height:7px; border-radius:50%; background:#E01E1E; flex-shrink:0; box-shadow:0 0 8px rgba(224,30,30,0.7); }
      .av-card__name { font-family:'Rajdhani',sans-serif; font-size:14px; font-weight:700; color:#fff; }
      .av-card video { width:100%; display:block; aspect-ratio:9/16; object-fit:cover; }
      .av-card__foot { padding:11px 15px 13px; border-top:1px solid rgba(255,255,255,0.06); }
      .av-card__link { font-family:'Rajdhani',sans-serif; font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.4); text-decoration:none; transition:color 0.2s; }
      .av-card__link:hover { color:#E01E1E; }
      @media(max-width:768px){
        .av-layout { grid-template-columns:1fr; gap:36px; padding:0 16px; }
        .av-text h2 { font-size:30px; }
        .av-cards { gap:10px; }
        .av-card:first-child { transform:rotate(-1deg); }
        .av-card:last-child { transform:rotate(1deg); margin-top:14px; }
      }
    </style>
    <div class="av-layout">
      <div class="av-text">
        <div class="av-text__tag">See It Work</div>
        <h2>Both Products<br><span style="color:#E01E1E">In Action</span></h2>
        <p>Real cars. Real water. No edits. Watch both products perform on actual vehicles with zero filters.</p>
        <div class="av-text__btns">
          <a href="nanowype-plus.html" class="av-text__btn av-text__btn--nano">Shop NanoWype+™ <span>1200 GSM →</span></a>
          <a href="wype-plus.html" class="av-text__btn av-text__btn--micro">Shop Micro wype+™ <span>Pro Grade →</span></a>
        </div>
      </div>
      <div class="av-cards">
        <div class="av-card">
          <div class="av-card__head"><span class="av-card__dot"></span><span class="av-card__name">NanoWype+™</span></div>
          <video src="assets/nanowype-demo.mp4" autoplay muted loop playsinline></video>
          <div class="av-card__foot"><a href="nanowype-plus.html" class="av-card__link">View Product →</a></div>
        </div>
        <div class="av-card">
          <div class="av-card__head"><span class="av-card__dot"></span><span class="av-card__name">Micro wype+™</span></div>
          <video src="assets/microwype-demo.mp4" autoplay muted loop playsinline style="transform:scale(1.15);transform-origin:center;"></video>
          <div class="av-card__foot"><a href="wype-plus.html" class="av-card__link">View Product →</a></div>
        </div>
      </div>
    </div>
  </section>

  <!-- GSM COMPARISON -->
  <section class="gsm-section" id="gsm">
    <div class="container">

      <div class="section-header">
        <div class="section-tag">The GSM Difference</div>
        <h2 class="section-title">Why <span class="accent-w">GSM matters</span> more than price</h2>
        <p class="section-sub">Higher GSM. Denser fibres. Better clean. It's that simple.</p>
      </div>

      <!-- What is GSM explainer -->
      <div class="gsm-explainer">
        <div class="gsm-explainer__item">
          <div class="gsm-explainer__stat" data-count="3" data-suffix="×">0×</div>
          <div class="gsm-explainer__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3h18M3 9h18M3 15h18M3 21h18"/></svg>
          </div>
          <h4>More fibres per cm²</h4>
          <p>Higher GSM means more split microfibre threads packed into every centimetre. More threads, more surface area to lift, trap and hold dirt, water and wax residue.</p>
        </div>
        <div class="gsm-explainer__item">
          <div class="gsm-explainer__stat" data-count="0" data-suffix=" scratches">0 scratches</div>
          <div class="gsm-explainer__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h4>Safer on paintwork</h4>
          <p>Dense fibres sit between any grit particle and your clear coat. Low GSM cloths drag grit across the paint surface. That's where swirl marks and micro-scratches come from.</p>
        </div>
        <div class="gsm-explainer__item">
          <div class="gsm-explainer__stat" data-count="300" data-suffix="+ washes">0+ washes</div>
          <div class="gsm-explainer__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <h4>Lasts longer</h4>
          <p>A denser cloth holds its structure through hundreds of washes. Budget cloths lose fibres, go flat and leave lint after just a few uses, costing you more in the long run.</p>
        </div>
      </div>

      <!-- Comparison bar chart -->
      <div class="gsm-compare">
        <h3 class="gsm-compare__title">How we stack up against the big brands</h3>

        <div class="gsm-compare__row gsm-compare__row--competitor">
          <div class="gsm-compare__brand">
            <div class="gsm-logo gsm-logo--costco">
              <img src="assets/costco-logo.png" alt="Costco Wholesale" style="height:32px;width:auto;object-fit:contain;">
            </div>
            <span class="gsm-compare__gsm-num">~400 GSM</span>
          </div>
          <div class="gsm-compare__bar-wrap">
            <div class="gsm-compare__bar gsm-compare__bar--low" style="--pct:25%"></div>
          </div>
          <div class="gsm-compare__verdict gsm-compare__verdict--bad">Basic household use</div>
        </div>

        <div class="gsm-compare__row gsm-compare__row--competitor">
          <div class="gsm-compare__brand">
            <div class="gsm-logo gsm-logo--halfords">
              <img src="assets/halfords-logo.jpg" alt="Halfords" style="height:28px;width:auto;object-fit:contain;border-radius:4px;">
            </div>
            <span class="gsm-compare__gsm-num">~600 GSM</span>
          </div>
          <div class="gsm-compare__bar-wrap">
            <div class="gsm-compare__bar gsm-compare__bar--mid" style="--pct:37.5%"></div>
          </div>
          <div class="gsm-compare__verdict gsm-compare__verdict--bad">Budget car cleaning</div>
        </div>

        <div class="gsm-compare__row gsm-compare__row--competitor">
          <div class="gsm-compare__brand">
            <div class="gsm-logo gsm-logo--generic">
              <span>Generic Brands</span>
            </div>
            <span class="gsm-compare__gsm-num">~800 GSM</span>
          </div>
          <div class="gsm-compare__bar-wrap">
            <div class="gsm-compare__bar gsm-compare__bar--mid" style="--pct:50%"></div>
          </div>
          <div class="gsm-compare__verdict gsm-compare__verdict--mid">Standard car care</div>
        </div>

        <div class="gsm-compare__row gsm-compare__row--nano">
          <div class="gsm-compare__brand">
            <div class="gsm-logo gsm-logo--wype">
              <img src="assets/logo.png" alt="wype" height="20">
              <strong>NanoWype+™</strong>
            </div>
            <span class="gsm-compare__gsm-num gsm-compare__gsm-num--nano">1200 GSM</span>
          </div>
          <div class="gsm-compare__bar-wrap">
            <div class="gsm-compare__bar gsm-compare__bar--nano" style="--pct:100%">
              <span class="gsm-compare__bar-label">Nano wave technology</span>
            </div>
          </div>
          <div class="gsm-compare__verdict gsm-compare__verdict--nano">Professional grade ★</div>
        </div>
      </div>

      <!-- Bottom proof points -->
      <div class="gsm-proof">
        <div class="gsm-proof__item">
          <span class="gsm-proof__num">3×</span>
          <span class="gsm-proof__desc">the fibre density of most supermarket cloths</span>
        </div>
        <div class="gsm-proof__divider"></div>
        <div class="gsm-proof__item">
          <span class="gsm-proof__num">4×</span>
          <span class="gsm-proof__desc">more absorbent than a standard Costco cloth</span>
        </div>
        <div class="gsm-proof__divider"></div>
        <div class="gsm-proof__item">
          <span class="gsm-proof__num">0</span>
          <span class="gsm-proof__desc">scratches, lint, or streaks on your paintwork</span>
        </div>
      </div>

    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="products" id="products">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">The Range</div>
        <h2 class="section-title">Two cloths. <span class="accent">Zero compromise.</span></h2>
        <p class="section-sub">Both XL. Both anti-snag. Both streak-free. Pick the weave that suits your detailing style.</p>
      </div>
      <div class="products__grid" style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">

        <!-- NanoWype+ -->
        <div class="product-card product-card--featured product-card--hero">
          <div class="product-card__tag" style="background:#E01E1E;color:#fff;">New · Nano Wave</div>
          <div class="product-card__visual product-card__visual--tall">
            <img id="nanoSlideImg" src="assets/nano-porsche-bonnet.jpg" alt="NanoWype+ microfibre towel" class="product-card__img" style="transition:opacity 0.5s ease;object-fit:cover;object-position:center center;">
            <button class="circ-gallery__arrow circ-gallery__arrow--prev" onclick="nanoNav(-1)" aria-label="Previous photo">
