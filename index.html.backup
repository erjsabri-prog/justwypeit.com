      <style>
        @media (max-width: 640px) {
          #products .products__grid { grid-template-columns: 1fr !important; }
        }
      </style>
      <script>
        (function(){
          var nanoImgs = [
            {src:'assets/nano-porsche-bonnet.jpg'},
            {src:'assets/nano-folded-side.jpg'},
            {src:'assets/nano-c63.jpg'},
            {src:'assets/nano-bonnet.jpg'}
          ];
          var microImgs = [
            {src:'assets/micro-911.jpg'},
            {src:'assets/micro-folded.jpg'},
            {src:'assets/micro-flat.jpg'}
          ];
          var nanoIdx = 0, microIdx = 0;
          var nanoEl  = document.getElementById('nanoSlideImg');
          var microEl = document.getElementById('microSlideImg');
          function goTo(el, imgs, idx){
            el.style.opacity = '0';
            setTimeout(function(){ el.src = imgs[idx].src; el.style.opacity = '1'; }, 400);
          }
          window.nanoNav  = function(dir){ nanoIdx  = (nanoIdx  + dir + nanoImgs.length)  % nanoImgs.length;  goTo(nanoEl,  nanoImgs,  nanoIdx);  };
          window.microNav = function(dir){ microIdx = (microIdx + dir + microImgs.length) % microImgs.length; goTo(microEl, microImgs, microIdx); };
        })();
      </script>
    </div>
  </section>


