  <!-- ORDER SECTION, simplified bundle picker → checkout -->
  <section class="order-section" id="order">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">Pre-Order Now</div>
        <h2 class="section-title">Ready to <span class="accent">just wype it?</span></h2>
        <p class="section-sub">Ships end of May 2026. Pick your bundle and check out in under 60 seconds.</p>
      </div>

      <!-- Product selector tabs -->
      <div style="display:flex;gap:0;max-width:600px;margin:0 auto 24px;border-radius:10px;overflow:hidden;border:1.5px solid rgba(255,255,255,0.15);">
        <button id="homeTabNano" onclick="setHomeProduct('nanowype')"
          style="flex:1;padding:14px 10px;font-family:'Rajdhani',sans-serif;font-size:15px;font-weight:700;letter-spacing:0.5px;border:none;cursor:pointer;transition:background 0.2s,color 0.2s;background:#E01E1E;color:#fff;">
          NanoWype+™ <span style="display:block;font-family:'Inter',sans-serif;font-size:11px;font-weight:500;opacity:0.85;">1200 GSM · Nano Wave</span>
        </button>
        <button id="homeTabWype" onclick="setHomeProduct('wype-plus')"
          style="flex:1;padding:14px 10px;font-family:'Rajdhani',sans-serif;font-size:15px;font-weight:700;letter-spacing:0.5px;border:none;cursor:pointer;transition:background 0.2s,color 0.2s;background:#111;color:#fff;">
          Micro wype+™ <span style="display:block;font-family:'Inter',sans-serif;font-size:11px;font-weight:500;opacity:0.85;">Pro Grade</span>
        </button>
      </div>

      <div class="p-bundles" style="max-width:600px;margin:0 auto 32px;">
        <div class="p-bundles__label">Choose your quantity</div>

        <label class="p-bundle" id="hb1">
          <input type="radio" name="homebundle" value="1" checked onchange="setHomeBundle(1)">
          <div class="p-bundle__inner">
            <div class="p-bundle__qty">1 towel</div>
            <div class="p-bundle__price-wrap">
              <div class="p-bundle__price" id="hbPrice1">£16.00<span class="p-bundle__per">/towel</span></div>
              <div class="p-bundle__delivery" id="hbDel1">+ £3.99 delivery</div>
            </div>
          </div>
        </label>

        <label class="p-bundle p-bundle--deal" id="hb2">
          <input type="radio" name="homebundle" value="2" onchange="setHomeBundle(2)">
          <div class="p-bundle__tag">SAVE 20%</div>
          <div class="p-bundle__inner">
            <div class="p-bundle__qty">2 towels</div>
            <div class="p-bundle__price-wrap">
              <div class="p-bundle__price" id="hbPrice2">£12.80<span class="p-bundle__per">/towel</span></div>
              <div class="p-bundle__total" id="hbTotal2">£25.60 total</div>
              <div class="p-bundle__delivery p-bundle__delivery--free">✓ Free delivery</div>
            </div>
          </div>
        </label>

        <label class="p-bundle p-bundle--best" id="hb3">
          <input type="radio" name="homebundle" value="5" onchange="setHomeBundle(5)">
          <div class="p-bundle__tag p-bundle__tag--best">BEST VALUE · SAVE 30%</div>
          <div class="p-bundle__inner">
            <div class="p-bundle__qty">5 towels</div>
            <div class="p-bundle__price-wrap">
              <div class="p-bundle__price" id="hbPrice5">£11.20<span class="p-bundle__per">/towel</span></div>
              <div class="p-bundle__total" id="hbTotal5">£56.00 total</div>
              <div class="p-bundle__delivery p-bundle__delivery--free">✓ Free delivery</div>
            </div>
          </div>
        </label>
      </div>

      <div style="text-align:center;margin-bottom:20px;">
        <!-- hidden anchor used by JS for redirect URL -->
        <a href="checkout.html?bundle=1&product=nanowype" id="homeCheckoutBtn" style="display:none;"></a>

        <!-- Slide-to-order -->
        <div class="slide-btn-wrap" id="slideBtnWrap">
          <div class="slide-btn__fill" id="slideBtnFill"></div>
          <div class="slide-btn__handle" id="slideBtnHandle">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </div>
          <span class="slide-btn__label" id="slideBtnLabel">Slide to Add to Basket</span>
        </div>

        <div style="margin-top:10px;color:rgba(255,255,255,0.28);font-family:'Inter',sans-serif;font-size:11.5px;letter-spacing:0.3px;display:flex;align-items:center;justify-content:center;gap:6px;">
          Apple Pay · Google Pay · Klarna · Card
        </div>
      </div>

    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <style>
      .footer { background: #0a0a0a; padding: 64px 0 0; }
      .footer__new-wrap {
        max-width: 1100px; margin: 0 auto; padding: 0 24px 48px;
        display: grid;
        grid-template-columns: minmax(280px, 380px) 1fr 1fr;
        gap: 48px;
        align-items: start;
      }
      /* Contact card */
      .footer__contact-card {
        border: 1.5px solid rgba(255,255,255,0.18);
        border-radius: 20px;
        padding: 28px 28px 0 28px;
        position: relative;
        overflow: hidden;
        min-height: 280px;
        display: flex;
        flex-direction: column;
      }
      .footer__contact-intro {
        font-family: var(--font-ui);
        font-size: 15px;
        color: rgba(255,255,255,0.75);
        line-height: 1.6;
        margin-bottom: 18px;
      }
      .footer__contact-label {
        font-family: var(--font-ui);
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 4px;
      }
      .footer__contact-email {
        font-family: var(--font-ui);
        font-size: 13px;
        color: rgba(255,255,255,0.6);
        text-decoration: underline;
        text-underline-offset: 3px;
        margin-bottom: 14px;
        display: block;
      }
      .footer__contact-email:hover { color: #fff; }
      .footer__contact-bottom {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-top: auto;
      }
      .footer__socials-new {
        display: flex;
        gap: 14px;
        padding-bottom: 28px;
      }
      .footer__social-new {
        color: rgba(255,255,255,0.55);
        transition: color 0.2s;
        display: flex;
      }
      .footer__social-new:hover { color: #fff; }
      /* Mascot */
      .footer__mascot-wrap {
        align-self: flex-end;
        margin-right: -28px;
        margin-bottom: -28px;
        flex-shrink: 0;
      }
      .footer__mascot-img {
        width: 180px;
        height: auto;
        display: block;
        border-radius: 0 0 18px 0;
      }
      /* Nav columns */
      .footer__col-new h4 {
        font-family: var(--font-ui);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #fff;
        margin-bottom: 24px;
      }
      .footer__col-new ul {
        display: flex;
        flex-direction: column;
        gap: 16px;
        list-style: none;
        padding: 0; margin: 0;
      }
      .footer__col-new a {
        font-family: var(--font-ui);
        font-size: 15px;
        color: rgba(255,255,255,0.5);
        text-decoration: none;
        transition: color 0.2s;
        display: block;
      }
      .footer__col-new a:hover { color: #fff; }
      /* Bottom bar */
      .footer__bar {
        border-top: 1px solid rgba(255,255,255,0.08);
        max-width: 1100px; margin: 0 auto;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--font-ui);
        font-size: 12px;
        color: rgba(255,255,255,0.28);
      }
      .footer__bar-legal { display: flex; gap: 20px; }
      .footer__bar-legal a { color: rgba(255,255,255,0.28); text-decoration: none; transition: color 0.2s; }
      .footer__bar-legal a:hover { color: rgba(255,255,255,0.6); }
      @media (max-width: 768px) {
        .footer__new-wrap { grid-template-columns: 1fr; gap: 36px; }
        .footer__bar { flex-direction: column; gap: 12px; text-align: center; }
        .footer__contact-card { min-height: auto; }
      }
    </style>
    <div class="footer__new-wrap">

      <!-- Contact card -->
      <div class="footer__contact-card">
        <p class="footer__contact-intro">Our team responds to all enquiries Monday through Saturday.</p>
        <p class="footer__contact-label">Customer service:</p>
        <a href="mailto:customer@justwypeit.com" class="footer__contact-email">customer@justwypeit.com</a>
        <p class="footer__contact-label">Trade enquiries:</p>
        <a href="mailto:customer@justwypeit.com" class="footer__contact-email">customer@justwypeit.com</a>
        <div class="footer__contact-bottom">
          <div class="footer__socials-new">
            <a href="https://www.instagram.com/justwypeit" target="_blank" rel="noopener" class="footer__social-new" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
